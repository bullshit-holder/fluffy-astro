<section
  id="contact"
  class="py-24 bg-taupe-800 text-taupe-100"
>

  <div class="max-w-3xl mx-auto px-6">

    <h2 class="text-4xl font-bold mb-10 text-taupe-50">
      Contact Us
    </h2>

    <form class="space-y-4">

      <input
        type="text"
        placeholder="Name"
        class="w-full rounded-xl bg-taupe-900 border border-taupe-700 p-4 text-taupe-50 placeholder:text-taupe-400 focus:outline-none focus:border-taupe-400 transition"
      />

      <input
        type="email"
        placeholder="Email"
        class="w-full rounded-xl bg-taupe-900 border border-taupe-700 p-4 text-taupe-50 placeholder:text-taupe-400 focus:outline-none focus:border-taupe-400 transition"
      />

      <textarea
        rows="6"
        placeholder="Message"
        class="w-full rounded-xl bg-taupe-900 border border-taupe-700 p-4 text-taupe-50 placeholder:text-taupe-400 focus:outline-none focus:border-taupe-400 transition"
      ></textarea>

      <button
        class="rounded-xl bg-taupe-50 text-taupe-900 px-6 py-3 font-medium hover:bg-taupe-200 transition"
      >
        Send Message
      </button>

    </form>

  </div>

</section>