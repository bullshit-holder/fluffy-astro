---
import { site } from './../data/site';
import { Image } from "astro:assets";
---
<footer class="border-t py-8 border-taupe-600 bg-taupe-900 text-taupe-400">
	<!-- Left aglined image beside text with copyright and bottom navigation -->
	 <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
		<div class="flex items-center gap-4">
			<Image
				src={site.logo.goat}
				alt={site.logo.alt}
				width={100}
				height={30}
				class="h-8 w-auto object-contain"
			/>
			<span class="text-sm text-taupe-400">{site.footer.text} © {new Date().getFullYear()}</span>
		</div>
		<nav class="flex gap-4">
			{site.navigation.map((item) => (
				<a
					href={item.href}
					class="text-sm text-taupe-400 hover:text-taupe-200 transition"
				>
					{item.label}
				</a>
			))}
		</nav>
	</div>
</footer>